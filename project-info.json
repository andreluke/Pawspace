{
  "name": "pawspace",
  "description": "Bot de Discord construído com Constatic Framework",
  "framework": {
    "name": "Constatic",
    "repo": "github.com/rinckodev/constatic",
    "docs": "constatic-docs.vercel.app",
    "baseVersion": "1.5.5"
  },
  "structure": {
    "entry": "src/index.ts",
    "commands": "src/discord/commands/public/",
    "events": "src/discord/events/",
    "responders": "src/discord/responders/"
  },
  "aliases": {
    "#base": "src/discord",
    "#env": "src/env",
    "#functions": "src/functions",
    "#database": "src/database",
    "#server": "src/server",
    "#menus": "src/menus",
    "#tools": "src/tools",
    "#lib/*": "src/lib/*",
    "#shared/*": "src/shared/*"
  },
  "scripts": {
    "dev": "Desenvolvimento com tsx",
    "dev:dev": "Desenvolvimento com tsx (ambiente dev)",
    "watch": "Watch mode com tsx",
    "watch:dev": "Watch mode (ambiente dev)",
    "build": "Compila com tsup",
    "start": "Executa build compilado",
    "start:dev": "Executa build compilado (ambiente dev)",
    "check": "TypeScript check"
  },
  "dependencies": {
    "@constatic/base": "latest",
    "@magicyan/discord": "1.7.0",
    "discord.js": "14.25.1",
    "zod": "4.1.11",
    "rou3": "0.7.10",
    "chalk": "5.6.2"
  }
}
